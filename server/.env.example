# Puerto del servidor
PORT=3000

# Entorno
NODE_ENV=development

# URL base de AnimeFlv
ANIMEFLV_BASE_URL=https://www3.animeflv.net

# CORS - URL del frontend en desarrollo
CORS_ORIGIN=http://localhost:5173

# Cache TTL en segundos (5 minutos por defecto)
CACHE_TTL=300

# Timeout para peticiones de scraping (ms)
SCRAPER_TIMEOUT=15000
